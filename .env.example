# ─────────────────────────────────────────────────────────────────────
# TBMN LearnWeb Connector — .env Beispiel
# Kopiere diese Datei nach .env und trage echte Werte ein.
# Die .env-Datei wird NIE committed (siehe .gitignore).
# ─────────────────────────────────────────────────────────────────────

# ─── Transport ──────────────────────────────────────────────────────
# stdio = lokaler Dev-Modus (Claude Desktop, Terminal)
# http  = Production-Modus (Railway, claude.ai-Connector)
MCP_TRANSPORT=stdio

# Nur relevant für http: Port + Host. Railway setzt PORT automatisch und
# überschreibt MCP_HTTP_PORT. Lokal: Default 3001/127.0.0.1.
# MCP_HTTP_PORT=3001
# MCP_HTTP_HOST=127.0.0.1

# Erlaubte Hosts für den HTTP-Server. Komma-getrennt oder JSON-Array.
# Im Production-Betrieb: eigene Railway-Domain + Railway-Healthcheck-Host.
# MCP_ALLOWED_HOSTS=learnweb-mcp-production.up.railway.app,healthcheck.railway.app

# Erlaubte CORS-Origins. Default deckt claude.ai/chatgpt ab.
# WICHTIG: Die eigene Railway-Domain muss zusätzlich aufgenommen werden,
# sonst schlägt der OAuth-Login-Formular-POST mit 403 fehl.
# MCP_ALLOWED_ORIGINS=https://claude.ai,https://claudeusercontent.com,https://learnweb-mcp-production.up.railway.app

# ─── Learnweb / Moodle Zugangsdaten ────────────────────────────────
# Die Tools werden nur registriert, wenn Username UND Passwort gesetzt sind.
LEARNWEB_URL=https://www.uni-muenster.de/LearnWeb/learnweb2
LEARNWEB_USERNAME=
LEARNWEB_PASSWORD=

# ─── Learnweb-Endpoint ─────────────────────────────────────────────
# Default: true. Auf "false" setzen, um den HTTP-Endpoint komplett zu deaktivieren
# (stdio-Modus läuft weiter).
# MCP_LEARNWEB_ENDPOINT_ENABLED=true

# ─── OAuth (nur für HTTP-Modus erforderlich) ───────────────────────

# Öffentliche Base-URL des Servers (ohne Pfad).
# MCP_PUBLIC_BASE_URL=https://learnweb-mcp-production.up.railway.app

# Statische OAuth-Client-Registry. Für claude.ai-Custom-Connector:
#   {"claude-custom-connector":{"client_id":"...","redirect_uris":["https://claude.ai/api/mcp/auth_callback"]}}
# MCP_OAUTH_STATIC_CLIENTS=

# Secrets für Cookies und JWTs. Mit `openssl rand -hex 32` erzeugen.
# MCP_OAUTH_COOKIE_SECRET=
# MCP_OAUTH_JWT_SECRET=

# TTLs (in Sekunden). Defaults: 600 (10min) / 2592000 (30 Tage).
# MCP_OAUTH_ACCESS_TTL_SECONDS=600
# MCP_OAUTH_REFRESH_TTL_SECONDS=2592000

# ─── Identity-Provider: "local" oder "oidc" ─────────────────────────
# Default: local, wenn MCP_OAUTH_LOCAL_LOGIN_* gesetzt ist, sonst oidc.
# MCP_OAUTH_IDENTITY_PROVIDER=local

# Für "local": Single-User-Zugang. Passwort wird gegen bcrypt-Hash NICHT geprüft,
# daher bitte einen starken zufälligen String verwenden.
# MCP_OAUTH_LOCAL_LOGIN_USERNAME=
# MCP_OAUTH_LOCAL_LOGIN_PASSWORD=
# MCP_OAUTH_LOCAL_LOGIN_SUB=
# MCP_OAUTH_LOCAL_LOGIN_EMAIL=

# Für "oidc": externer OpenID-Connect-Provider (Google, etc.).
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# Whitelist der erlaubten Emails (Komma-getrennt oder JSON-Array).
# MCP_OAUTH_ALLOWED_EMAILS=

# ─── Persistence ──────────────────────────────────────────────────
# Redis-URL für OAuth-Sessions. In Production erforderlich — sonst verlieren
# alle Auth-Codes und Refresh-Tokens bei einem Redeploy ihren State.
# REDIS_URL=

# Explizites Opt-in für den In-Memory-Store in Production (Burn-In-Phase).
# ACHTUNG: Nach jedem Redeploy muss man sich in claude.ai neu authentifizieren.
# MCP_OAUTH_ALLOW_IN_MEMORY_STORE=false
