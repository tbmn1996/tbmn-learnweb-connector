{
  "name": "tbmn-learnweb-connector",
  "version": "1.0.0",
  "private": true,
  "description": "MCP-Server als claude.ai-Connector für die WWU Moodle-Instanz (Learnweb)",
  "main": "dist/mcp-server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/mcp-server.ts",
    "keychain:bootstrap": "bash ./scripts/bootstrap-keychain.sh",
    "start:stdio:keychain": "bash ./scripts/start-stdio-keychain.sh",
    "codex:mcp:register": "bash ./scripts/register-codex-mcp.sh",
    "start": "node dist/mcp-server.js",
    "start:http": "MCP_TRANSPORT=http node dist/mcp-server.js",
    "test": "npm run build && node --test test/**/*.test.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.0",
    "axios-cookiejar-support": "^6.0.5",
    "cheerio": "^1.1.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "jose": "^6.2.2",
    "redis": "^5.12.1",
    "tough-cookie": "^6.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4"
  }
}
